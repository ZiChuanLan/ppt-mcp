# ppt-mcp 环境变量示例

# 目标 ppt 服务根地址，不要带 /api/v1
PPT_API_BASE_URL=http://127.0.0.1:8000

# MCP 调用 ppt API 的超时时间，单位秒
PPT_API_TIMEOUT_SECONDS=120

# 如果后端开启了 API_BEARER_TOKEN，这里填同一个值
PPT_API_BEARER_TOKEN=

# 高层 route workflow 的本地持久化目录。
# 默认会写到仓库内 var/route-workflows，用于在 MCP 宿主重启后继续沿用同一个 route_workflow_id。
PPT_MCP_ROUTE_WORKFLOW_STORE_DIR=

# 高层 route workflow 的保留时长，单位秒。
# 到期后即使本地文件还在，也会被视为过期并要求从 ppt_check_route 重新开始。
PPT_MCP_ROUTE_WORKFLOW_TTL_SECONDS=3600

# MinerU 云解析 token
MINERU_API_TOKEN=

# 百度文档解析凭据
BAIDU_API_KEY=
BAIDU_SECRET_KEY=
BAIDU_APP_ID=

# 通用远程视觉/OCR 模型 key
SILICONFLOW_API_KEY=

# 以下变量只在远程 ppt-mcp-remote 模式下需要

# 远程 MCP 监听地址
PPT_MCP_BIND_HOST=0.0.0.0

# 远程 MCP 监听端口
PPT_MCP_BIND_PORT=8080

# 远程 MCP 对外访问地址
PPT_MCP_PUBLIC_BASE_URL=http://127.0.0.1:8080

# 远程 MCP 自己的入口 Bearer
PPT_MCP_SERVER_TOKEN=

# 远程 profile 配置文件路径
PPT_MCP_PROFILE_STORE=

# 远程上传缓存目录
PPT_MCP_DATA_DIR=
